{
  "name": "related-tests-controller",
  "displayName": "Related Tests Controller",
  "description": "Adds a second Testing controller that runs related pytest files from source metadata.",
  "version": "0.1.0",
  "publisher": "kishanpatel",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Testing"
  ],
  "activationEvents": [
    "*",
    "onCommand:relatedTests.refreshController",
    "onCommand:relatedTests.refreshItem"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "relatedTests.refreshController",
        "title": "Related Tests: Refresh Controller"
      },
      {
        "command": "relatedTests.refreshItem",
        "title": "Refresh Related Tests"
      }
    ],
    "menus": {
      "testing/item/context": [
        {
          "command": "relatedTests.refreshItem",
          "when": "controllerId == 'relatedTests'",
          "group": "inline@1"
        },
        {
          "command": "relatedTests.refreshItem",
          "when": "controllerId == 'relatedTests'",
          "group": "2_refresh"
        }
      ]
    },
    "configuration": {
      "title": "Related Tests",
      "properties": {
        "relatedTests.pythonCommand": {
          "type": "string",
          "default": "",
          "description": "Optional Python executable used to inspect metadata and run pytest. Leave empty to reuse the workspace interpreter or .venv/bin/python."
        },
        "relatedTests.pytestArgs": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Additional arguments passed to pytest for the Related Tests controller."
        }
      }
    }
  }
}
